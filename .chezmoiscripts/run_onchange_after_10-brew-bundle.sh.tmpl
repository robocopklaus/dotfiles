#!/usr/bin/env bash
set -Eeuo pipefail

# Installs Homebrew packages, casks, and Mac App Store apps from Brewfile.
# Ensures Xcode CLT and Homebrew exist first. Formulae are installed as the
# blocking base step; casks and MAS apps run separately so optional app failures
# do not abort the rest of chezmoi apply.
#
# Re-run this script when Brewfile changes.
# Brewfile sha256: {{ include "Brewfile" | sha256sum }}

if [[ "$(uname)" != "Darwin" ]]; then
  exit 0
fi

homebrew_installer=""
mas_brewfile=""
sudo_keepalive_pid=""

cleanup() {
  if [[ -n "$sudo_keepalive_pid" ]]; then
    kill "$sudo_keepalive_pid" 2>/dev/null || true
  fi

  if [[ -n "$homebrew_installer" && -f "$homebrew_installer" ]]; then
    rm -f "$homebrew_installer"
  fi

  if [[ -n "$mas_brewfile" && -f "$mas_brewfile" ]]; then
    rm -f "$mas_brewfile"
  fi
}
trap cleanup EXIT

have_command_line_tools() {
  xcode-select -p >/dev/null 2>&1
}

ensure_command_line_tools() {
  local install_output
  local timeout_seconds=3600
  local waited_seconds=0

  if have_command_line_tools; then
    return 0
  fi

  echo "Xcode Command Line Tools not found; opening installer."
  install_output="$(xcode-select --install 2>&1)" || true
  if [[ -n "$install_output" ]]; then
    echo "$install_output"
  fi

  echo "Waiting for Xcode Command Line Tools installation to finish."
  until have_command_line_tools; do
    sleep 10
    waited_seconds=$((waited_seconds + 10))

    if ((waited_seconds >= timeout_seconds)); then
      echo "Timed out waiting for Xcode Command Line Tools installation." >&2
      echo "Finish the installation, then run chezmoi apply again." >&2
      exit 1
    fi
  done

  echo "Xcode Command Line Tools are installed."
}

# Cask installers prompt for sudo at unpredictable points during a single
# bundle run. Refreshing the timestamp in the background avoids stalls in
# the middle of a non-interactive install.
start_sudo_keepalive() {
  if [[ -n "$sudo_keepalive_pid" ]]; then
    return 0
  fi

  if [[ ! -t 0 || ! -t 1 ]] || ! command -v sudo >/dev/null 2>&1; then
    return 0
  fi

  echo "Refreshing sudo credentials for Homebrew setup."
  sudo -v

  while true; do
    sudo -n true
    sleep 60
  done 2>/dev/null &
  sudo_keepalive_pid="$!"
}

load_homebrew() {
  local brew_path

  if command -v brew >/dev/null 2>&1; then
    return 0
  fi

  for brew_path in /opt/homebrew/bin/brew /usr/local/bin/brew; do
    if [[ -x "$brew_path" ]]; then
      eval "$("$brew_path" shellenv)"
      return 0
    fi
  done

  return 1
}

install_homebrew() {
  echo "Homebrew not found; installing Homebrew."

  homebrew_installer="$(mktemp "${TMPDIR:-/tmp}/homebrew-install.XXXXXX")"
  curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh -o "$homebrew_installer"

  if [[ -t 0 && -t 1 ]]; then
    /bin/bash "$homebrew_installer"
  else
    NONINTERACTIVE=1 /bin/bash "$homebrew_installer"
  fi
}

run_with_timeout() {
  local timeout_seconds="$1"
  shift

  local command_pid=""
  local waited_seconds=0

  "$@" &
  command_pid="$!"

  while kill -0 "$command_pid" 2>/dev/null; do
    if ((waited_seconds >= timeout_seconds)); then
      pkill -TERM -P "$command_pid" 2>/dev/null || true
      kill "$command_pid" 2>/dev/null || true
      wait "$command_pid" 2>/dev/null || true
      return 124
    fi

    sleep 1
    waited_seconds=$((waited_seconds + 1))
  done

  wait "$command_pid"
}

# Install Homebrew formulae as the blocking base dependency step. Casks and
# MAS apps are handled separately below so GUI/App Store failures stay isolated.
install_homebrew_formulae() {
  local brewfile="$1"

  if HOMEBREW_BUNDLE_CASK_SKIP=1 HOMEBREW_BUNDLE_MAS_SKIP=1 brew bundle check --file "$brewfile" >/dev/null; then
    echo "Homebrew formulae already satisfied."
  else
    HOMEBREW_BUNDLE_CASK_SKIP=1 HOMEBREW_BUNDLE_MAS_SKIP=1 brew bundle --file "$brewfile"
  fi
}

# Install casks one by one. A single failed GUI app install should not make a
# fresh machine bootstrap unusable; re-running chezmoi apply retries failures.
install_cask_apps() {
  local brewfile="$1"
  local cask_app
  local cask_apps=()
  local failed_apps=()

  while IFS= read -r cask_app; do
    [[ -n "$cask_app" ]] && cask_apps+=("$cask_app")
  done < <(HOMEBREW_NO_AUTO_UPDATE=1 brew bundle list --cask --file "$brewfile" 2>/dev/null || true)

  if ((${#cask_apps[@]} == 0)); then
    return 0
  fi

  start_sudo_keepalive

  for cask_app in "${cask_apps[@]}"; do
    if brew list --cask "$cask_app" >/dev/null 2>&1; then
      echo "Cask already installed: $cask_app"
      continue
    fi

    if HOMEBREW_NO_AUTO_UPDATE=1 brew install --cask "$cask_app"; then
      echo "Installed cask: $cask_app"
    else
      echo "Could not install optional cask: $cask_app" >&2
      failed_apps+=("$cask_app")
    fi
  done

  if ((${#failed_apps[@]} > 0)); then
    echo "Some optional casks could not be installed: ${failed_apps[*]}" >&2
    echo "Run chezmoi apply again later to retry them." >&2
  fi
}

# Install MAS entries against a stripped-down Brewfile under a timeout so
# a missing App Store login (or a flaky `mas` call) does not block the
# rest of the bundle.
install_mas_apps() {
  local brewfile="$1"

  mas_brewfile="$(mktemp "${TMPDIR:-/tmp}/mas-brewfile.XXXXXX")"
  awk '/^[[:space:]]*mas[[:space:]]+"/ { print }' "$brewfile" >"$mas_brewfile"

  if [[ ! -s "$mas_brewfile" ]]; then
    return 0
  fi

  if ! command -v mas >/dev/null 2>&1; then
    echo "mas not found; skipping Mac App Store apps." >&2
    return 0
  fi

  echo "Installing Mac App Store apps when App Store is ready."
  if run_with_timeout 900 brew bundle --file "$mas_brewfile"; then
    echo "Mac App Store apps are installed."
  else
    echo "Mac App Store apps could not be installed automatically." >&2
    echo "Sign in to the App Store, then run chezmoi apply again." >&2
  fi
}

ensure_command_line_tools

if ! load_homebrew; then
  start_sudo_keepalive
  install_homebrew
fi

if ! load_homebrew; then
  echo "Homebrew installation completed, but brew is not on PATH." >&2
  exit 1
fi

source_dir="${CHEZMOI_SOURCE_DIR:-}"
if [[ -z "$source_dir" ]] && command -v chezmoi >/dev/null 2>&1; then
  source_dir="$(chezmoi source-path)"
fi
if [[ -z "$source_dir" ]]; then
  source_dir="$HOME/.local/share/chezmoi"
fi

brewfile="$source_dir/Brewfile"
if [[ ! -f "$brewfile" ]]; then
  echo "Brewfile not found at $brewfile; skipping brew bundle." >&2
  exit 0
fi

start_sudo_keepalive
install_homebrew_formulae "$brewfile"
install_cask_apps "$brewfile"
install_mas_apps "$brewfile"
