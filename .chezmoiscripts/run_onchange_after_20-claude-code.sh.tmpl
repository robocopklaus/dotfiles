#!/usr/bin/env bash
set -Eeuo pipefail

if [[ "$(uname)" != "Darwin" ]]; then
  exit 0
fi

claude_installer=""

cleanup() {
  if [[ -n "$claude_installer" && -f "$claude_installer" ]]; then
    rm -f "$claude_installer"
  fi
}
trap cleanup EXIT

have_claude_code() {
  command -v claude >/dev/null 2>&1 || [[ -x "$HOME/.local/bin/claude" ]]
}

if have_claude_code; then
  echo "Claude Code already installed."
  exit 0
fi

echo "Claude Code not found; installing with the native installer."
claude_installer="$(mktemp "${TMPDIR:-/tmp}/claude-code-install.XXXXXX")"
curl -fsSL https://claude.ai/install.sh -o "$claude_installer"
bash "$claude_installer"
